@page "/blackscholespricer"
@using MudBlazor
@using MudBlazor.Charts
@using Pricer.Numerics

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    <MudPaper Elevation="4" Class="pa-6">

        <MudText Typo="Typo.h5" GutterBottom="true">
            Black–Scholes Pricer
        </MudText>

        <MudGrid>

            <MudItem xs="12" sm="6">
                <MudSelect T="OptionType" Label="Option Type" @bind-Value="optionType">
                    <MudSelectItem Value="OptionType.Call">Call</MudSelectItem>
                    <MudSelectItem Value="OptionType.Put">Put</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="double" Label="Underlying Price (S)" @bind-Value="underlyingPrice" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="double" Label="Strike (K)" @bind-Value="strike" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="double" Label="Interest Rate (r)" @bind-Value="interestRate" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="double" Label="Volatility (σ)" @bind-Value="volatility" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudTextField T="double" Label="Time to Maturity (T)" @bind-Value="timeToMaturity" />
            </MudItem>

        </MudGrid>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4"
                   OnClick="CalculatePrice">
            Calculate Price
        </MudButton>

        @if (price.HasValue)
        {
            <MudAlert Severity="Severity.Success" Class="mt-4">
                Price: @price.Value.ToString("F4")
            </MudAlert>
        }

    </MudPaper>


    <MudPaper Elevation="4" Class="pa-6 mt-6">

        <MudText Typo="Typo.h6" GutterBottom="true">
            Implied Volatility
        </MudText>

        <MudTextField T="double" Label="Market Price"
                      @bind-Value="marketPrice" Class="mb-4" />

        <MudButton Variant="Variant.Filled"
                   Color="Color.Secondary"
                   OnClick="ComputeImpliedVol">
            Compute Black–Scholes Implied Vol
        </MudButton>

        @if (impliedVol.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                Black–Scholes Implied Vol: @impliedVol.Value.ToString("F6")
            </MudAlert>
        }

        <MudButton Variant="Variant.Outlined"
                   Color="Color.Tertiary"
                   Class="mt-4"
                   OnClick="ComputeBachelierImpliedVol">
            Compute Bachelier ATM Vol
        </MudButton>

        @if (bachelierImpliedVol.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                Bachelier ATM Vol: @bachelierImpliedVol.Value.ToString("F6")
            </MudAlert>
        }

    </MudPaper>

    <MudPaper Elevation="4" Class="pa-6 mt-6">

        <MudText Typo="Typo.h6" GutterBottom="true">
            Price vs Underlying
        </MudText>

        <MudText Typo="Typo.body2" Class="mb-2">
            As T → 0 the Black–Scholes price converges towards intrinsic value.
        </MudText>

        <MudText Typo="Typo.subtitle2">Time to Maturity (T)</MudText>

        <MudSlider Min="0.01"
                   Max="2.0"
                   Step="0.01"
                   Immediate="true"
                   @bind-Value="chartT" />

        <MudText Typo="Typo.body2" Class="mb-4">
            T = @chartT.ToString("F2") years
        </MudText>

        <MudChart ChartType="ChartType.Line"
                  ChartSeries="@chartSeries"
                  XAxisLabels="@chartLabels"
                  Width="100%"
                  Height="350px"
                  ChartOptions="_chartOptions" />

    </MudPaper>

</MudContainer>
@code {

    private OptionType optionType = OptionType.Call;

    private double underlyingPrice = 100;
    private double strike = 100;
    private double interestRate = 0.001;
    private double volatility = 0.5;
    private double timeToMaturity = 1.0;

    private double? price;
    private string? errorMessage;

    private double marketPrice = 10.0;
    private double tolerance = 1e-8;
    private int maxIterations = 100;
    private double? impliedVol;
    private double? bachelierImpliedVol;

    private double _chartT = 1.0;
    private double chartT
    {
        get => _chartT;
        set
        {
            if (Math.Abs(_chartT - value) < 1e-10) return;
            _chartT = value;
            BuildChart();
        }
    }

    private ChartSeries<double> bsSeries = new();
    private ChartSeries<double> intrinsicSeries = new();
    private List<ChartSeries<double>> chartSeries = new();
    private string[] chartLabels = Array.Empty<string>();

    private readonly LineChartOptions _chartOptions = new()
    {
        YAxisLines = false,
        XAxisLines = false,
        ShowDataMarkers = false,
        LineStrokeWidth = 2,
        XAxisTitle = "Underlying price S",
        YAxisTitle = "Option value"
    };

    protected override void OnInitialized()
    {
        BuildChart();
    }

    private void CalculatePrice()
    {
        var blackScholesPricer = new BlackScholes(
            optionType,
            interestRate,
            timeToMaturity,
            volatility,
            strike,
            underlyingPrice
        );

        price = blackScholesPricer.Price();
    }

    private void ComputeImpliedVol()
    {
        impliedVol = ImpliedVolatilityCalculator.Compute(
            optionType,
            marketPrice,
            interestRate,
            timeToMaturity,
            strike,
            underlyingPrice,
            0.2D,
            tolerance,
            maxIterations
        );
    }

    private void ComputeBachelierImpliedVol()
    {
        bachelierImpliedVol = ImpliedVolatilityCalculator.BachelierImpliedVolATM(marketPrice, underlyingPrice, timeToMaturity, interestRate);
    }

private void BuildChart()
    {
        var sValues = Enumerable.Range(60, 81).Select(i => (double)i).ToArray();

        var bsData = sValues.Select(s =>
        {
            var bs = new BlackScholes(optionType, interestRate, _chartT, volatility, strike, s);
            return bs.Price();
        }).ToArray();

        var intrinsicData = sValues
             .Select(s => optionType == OptionType.Call
                 ? Math.Max(s - strike, 0.0)
                 : Math.Max(strike - s, 0.0))
             .ToArray();

        chartLabels = sValues.Select(s => s.ToString("F0")).ToArray();

        bsSeries = new ChartSeries<double>
        {
            Name = "BS Call Price",
            Data = bsData,
            Visible = true
        };

        intrinsicSeries = new ChartSeries<double>
        {
            Name = "Intrinsic Value",
            Data = intrinsicData,
            Visible = true
        };

        chartSeries = new List<ChartSeries<double>> { bsSeries, intrinsicSeries };

        StateHasChanged();
    }
}